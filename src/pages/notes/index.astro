---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { categoryLabels, formatDate, getAllNotes } from "../../lib/notes";

const notes = await getAllNotes();
const selectedCategory = Astro.url.searchParams.get("category");
const visibleNotes = selectedCategory ? notes.filter((note) => note.category === selectedCategory) : notes;
---

<BaseLayout title="笔记 | ProIg-Chaa">
  <section class="page-head">
    <p class="eyebrow">Notes</p>
    <h1>AI 学习笔记</h1>
    <p>按主题自动收集当前仓库里的 Markdown。新笔记放进 `notes/` 后，构建时会进入这个列表。</p>
  </section>

  <div class="filter-row" aria-label="笔记分类">
    <a class={selectedCategory ? "" : "active"} href="/notes/">全部</a>
    {Object.entries(categoryLabels).map(([key, label]) => (
      <a class={selectedCategory === key ? "active" : ""} href={`/notes/?category=${key}`}>{label}</a>
    ))}
  </div>

  <section class="note-list">
    {visibleNotes.map((note) => (
      <article class="note-row">
        <a href={note.url}>
          <span class="meta">{note.categoryLabel} · {formatDate(note.updated)}</span>
          <h2>{note.title}</h2>
          <p>{note.summary}</p>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
