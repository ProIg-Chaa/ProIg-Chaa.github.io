---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, getAllNotes, getCategoryEntries } from "../../lib/notes";

const notes = await getAllNotes();
const categories = getCategoryEntries(notes);
---

<BaseLayout title="笔记 | ProIg-Chaa">
  <section class="page-head">
    <p class="eyebrow">Notes</p>
    <h1>AI 学习笔记</h1>
    <p>按主题自动收集当前仓库里的 Markdown。新笔记放进 `notes/` 后，构建时会进入这个列表。</p>
  </section>

  <div class="filter-row" aria-label="笔记分类">
    <a class="active" href="/notes/">全部</a>
    {categories.map((category) => (
      <a href={category.url}>{category.label}</a>
    ))}
  </div>

  <section class="note-list">
    {notes.map((note) => (
      <article class="note-row">
        <a href={note.url}>
          <span class="meta">{note.categoryLabel} · {formatDate(note.updated)}</span>
          <h2>{note.title}</h2>
          <p>{note.summary}</p>
        </a>
      </article>
    ))}
  </section>
</BaseLayout>
